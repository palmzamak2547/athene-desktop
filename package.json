{
  "name": "athene-desktop",
  "version": "0.1.0",
  "description": "Athene Desktop — a free, local-first AI chat app on the open Athene engine. Part of the Athene suite.",
  "type": "module",
  "main": "main.js",
  "author": "Anuthin Danoi",
  "scripts": {
    "start": "electron .",
    "prepare-engine": "node scripts/prepare-engine.mjs",
    "lint": "node --check main.js && node --check preload.cjs && node --check lib/providers.js && node --check lib/engine.js && node --check lib/config.js && node --check renderer/renderer.js && node --check scripts/prepare-engine.mjs && node --check scripts/before-pack.cjs && node --check scripts/make-portable-zip.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis zip",
    "portable": "npm run pack && node scripts/make-portable-zip.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "ai": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.athene.desktop",
    "productName": "Athene",
    "beforePack": "scripts/before-pack.cjs",
    "files": [
      "main.js",
      "preload.cjs",
      "lib/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/athene",
        "to": "athene",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "renderer/brand/icon-512.png",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "Athene-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}

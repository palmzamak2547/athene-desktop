{
  "name": "athene-desktop",
  "version": "0.1.0",
  "description": "Athene Desktop — a free, local-first AI chat app on the open Athene engine. Part of the Athene suite.",
  "type": "module",
  "main": "main.js",
  "author": "Anuthin Danoi",
  "scripts": {
    "start": "electron .",
    "lint": "node --check main.js && node --check lib/providers.js && node --check lib/engine.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "ai": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.athene.desktop",
    "productName": "Athene",
    "files": [
      "main.js",
      "preload.cjs",
      "lib/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "renderer/brand/icon-512.png",
      "target": [
        "nsis"
      ],
      "artifactName": "Athene-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
